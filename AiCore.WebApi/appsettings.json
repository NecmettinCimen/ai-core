{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "EnableConsoleLogging": true,
    "EnableFileLogging": true,
    "LogPath": "logs",
    "SeqUrl": "http://localhost:5341",
    "SeqApiKey": "",
    "Serilog": {
      "MinimumLevel": {
        "Default": "Information",
        "Override": {
          "Microsoft": "Warning",
          "System": "Warning",
          "Microsoft.AspNetCore": "Warning"
        }
      },
      "WriteTo": [
        {
          "Name": "Console",
          "Args": {
            "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{SourceContext}] [{RequestId}] {Message:lj}{NewLine}{Exception}"
          }
        },
        {
          "Name": "File",
          "Args": {
            "path": "logs/log-.txt",
            "rollingInterval": "Day",
            "retainedFileCountLimit": 30,
            "fileSizeLimitBytes": 104857600,
            "rollOnFileSizeLimit": true,
            "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{SourceContext}] [{RequestId}] {Message:lj}{NewLine}{Exception}"
          }
        }
      ],
      "Enrich": [
        "FromLogContext",
        "WithMachineName",
        "WithEnvironmentName",
        "WithProcessId",
        "WithThreadId"
      ]
    }
  },
  "AllowedHosts": "*",
  "AiSettings": {
    "Provider": "Ollama",
    "BaseUrl": "http://ollama:11434",
    "Model": "llama3",
    "Timeout": 30000,
    "MaxRetries": 3,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerDuration": 30
  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 5,
    "EnableDistributedCache": true,
    "CacheKeyPrefix": "AiCore:"
  },
  "ConnectionStrings": {
    "Redis": "redis:6379"
  },
  "RateLimiting": {
    "Enabled": true,
    "General": {
      "PermitLimit": 100,
      "Window": "00:01:00",
      "SegmentPerWindow": 10
    },
    "AiAssistant": {
      "PermitLimit": 20,
      "Window": "00:01:00",
      "SegmentPerWindow": 5
    },
    "HealthChecks": {
      "PermitLimit": 1000,
      "Window": "00:01:00"
    },
    "Documentation": {
      "PermitLimit": 100,
      "Window": "00:01:00"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "AiCore.WebApi",
    "ServiceVersion": "1.0.0",
    "EnableMetrics": true,
    "EnableTracing": true,
    "Prometheus": {
      "Enabled": true,
      "Endpoint": "/metrics"
    },
    "Jaeger": {
      "Enabled": false,
      "Endpoint": "http://localhost:14268/api/traces"
    }
  },
  "HealthChecks": {
    "Enabled": true,
    "PollingInterval": "00:00:30",
    "FailureThreshold": 3,
    "SuccessThreshold": 2
  },
  "Security": {
    "EnableCors": true,
    "CorsOrigins": ["http://localhost:3000", "http://localhost:8080"],
    "EnableHttpsRedirection": true,
    "EnableHsts": true,
    "HstsMaxAge": 31536000,
    "EnableSecurityHeaders": true
  },
  "Monitoring": {
    "EnableApplicationInsights": false,
    "EnablePrometheus": true,
    "EnableDiagnostics": true
  },
  "Features": {
    "EnableApiVersioning": true,
    "EnableSwagger": true,
    "EnableHealthChecks": true,
    "EnableRateLimiting": true,
    "EnableDistributedTracing": true,
    "EnableMetrics": true
  }
}
